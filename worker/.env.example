# Worker (Phase 4 · Step 3) — OpenRouter config. Copy to worker/.env and fill in.
# .env is gitignored; never commit your key.

# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Any OpenRouter model slug. Examples:
#   openai/gpt-4o-mini          (cheap, capable default)
#   anthropic/claude-3.5-sonnet (Claude via OpenRouter)
#   google/gemini-flash-1.5
LLM_MODEL=openai/gpt-4o-mini

# Worker BASE URL the Node gateway forwards to (gateway-side, not read by the worker).
# Defaults to http://localhost:8000; the gateway appends /auto-furnish and /generate-plan.
# WORKER_URL=http://localhost:8000
